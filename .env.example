# Song generation strategy: 'mock' (offline/testing) or 'suno' (real API)
GENERATOR_STRATEGY=mock

# Required only when GENERATOR_STRATEGY=suno
# Get your key at https://sunoapi.org/api-key
SUNO_API_KEY=your_suno_api_key_here

# Google OAuth 2.0 — get credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
